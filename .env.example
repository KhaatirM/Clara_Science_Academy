# Copy to .env and fill in values. Never commit .env to git.

# Email (Google Workspace SMTP)
MAIL_PASSWORD=your-google-app-password-here

# Google Admin SDK Directory API (Service Account + domain-wide delegation)
# Example if you rename the file to 'google-admin-key.json'
GOOGLE_DIRECTORY_SERVICE_ACCOUNT_FILE="google-admin-key.json"
# Admin email to impersonate (must be a Workspace admin)
GOOGLE_DIRECTORY_DELEGATED_ADMIN="admin@clarascienceacademy.org"

# Default school timezone (IANA) when Tech has not set a database override.
# Tech can change the live zone for everyone under System Management → Configuration.
# SCHOOL_TIMEZONE=America/New_York
