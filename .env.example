# Copy to .env and fill in values. Never commit .env to git.

# Email (Google Workspace SMTP; donotrespond@… sends staff welcome/sign-in messages)
MAIL_PASSWORD=your-google-app-password-here
# Use an App Password if the account has 2-Step Verification. From address should match MAIL_USERNAME.
# MAIL_USERNAME=donotrespond@clarascienceacademy.org
# Optional: Message-ID domain (defaults to domain part of MAIL_USERNAME). Must be your real sending domain.
# MAIL_MESSAGE_ID_DOMAIN=clarascienceacademy.org
# Optional: monitored Reply-To (office@…) — often reduces spam folder placement vs no Reply-To on a no-reply From.
# MAIL_REPLY_TO=office@clarascienceacademy.org
# In Google Admin: turn on DKIM for the domain; keep SPF including Google. Check postmaster.google.com.
# Optional: absolute site URL for login links in those emails (e.g. https://app.clarascienceacademy.org)
# PUBLIC_BASE_URL=

# Google Admin SDK Directory API (Service Account + domain-wide delegation)
# Example if you rename the file to 'google-admin-key.json'
GOOGLE_DIRECTORY_SERVICE_ACCOUNT_FILE="google-admin-key.json"
# Admin email to impersonate (must be a Workspace admin)
GOOGLE_DIRECTORY_DELEGATED_ADMIN="admin@clarascienceacademy.org"

# Default school timezone (IANA) when Tech has not set a database override.
# Tech can change the live zone for everyone under System Management → Configuration.
# SCHOOL_TIMEZONE=America/New_York
